# ============================================================
#  ChronoGest - Variables de entorno para PRODUCCIÓN
# ============================================================
# Copiar este archivo a .env y completar los valores sensibles.
# NO commitear .env en el repositorio.
# ============================================================

# ── Docker Registry / Imágenes ───────────────────────────────
REGISTRY=docker.io
IMAGE_PREFIX=chronogest
TAG=latest

# ── PostgreSQL (Base de datos maestra) ───────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_ESTO_POR_PASSWORD_SEGURA
POSTGRES_DB=sena_db

# ── PostgreSQL (Base de datos secundaria / legacy) ────────────
DB2_NAME=proyecto_formativo_db

# ── Redis ──────────────────────────────────────────────────────
# Redis no requiere variables adicionales en modo básico
# Si usas AUTH en Redis, añade: REDIS_PASSWORD=...

# ── Backend (NestJS) ──────────────────────────────────────────
NODE_ENV=production
PORT=3001

# JWT (generar con: openssl rand -base64 64)
JWT_SECRET=CAMBIAR_ESTO_POR_CLAVE_JWT_MUY_SEGURA_DE_AL_MENOS_32_CARACTERES
JWT_EXPIRES_IN=24h

# Email (SMTP para notificaciones)
EMAIL_USER=
EMAIL_PASS=

# CORS (dominio público del frontend)
CORS_ORIGIN=https://chronogest.tu-dominio.com

# Tenant DB
TENANT_MAX_POOLS=20

# ── Face Service (Python FastAPI) ─────────────────────────────
# Variables adicionales si se requieren en el futuro
# FACE_DETECTION_BACKEND=opencv
# FACE_RECOGNITION_MODEL=ArcFace

# ── Frontend (Angular + nginx) ──────────────────────────────
# El frontend en producción se sirve estáticamente desde nginx.
# El proxy inverso al backend está configurado en nginx.conf.
# No se requieren variables de entorno adicionales.

# ── SSL / HTTPS (opcional) ───────────────────────────────────
# Si usas certificados propios en vez de un reverse proxy externo:
# SSL_CERT_PATH=/etc/nginx/certs/fullchain.pem
# SSL_KEY_PATH=/etc/nginx/certs/privkey.pem
