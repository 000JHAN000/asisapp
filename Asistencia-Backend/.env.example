PORT=3001
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=5440
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI
DB_NAME=sena_db

DB2_HOST=127.0.0.1
DB2_PORT=5440
DB2_USER=postgres
DB2_PASSWORD=TU_PASSWORD_AQUI
DB2_NAME=proyecto_formativo_db

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=TU_JWT_SECRET_AQUI
JWT_EXPIRES_IN=24h

EMAIL_USER=
EMAIL_PASS=

CORS_ORIGIN=http://localhost:4200
UPLOAD_DIR=uploads

# ============================================================
#  MULTITENANCY (Database-per-Tenant)
# ============================================================
# El catálogo de tenants/sedes vive en la BD maestra (DB_NAME).
# Cada sede tiene su propia base de datos física, registrada en
# la tabla 'tenants'. El frontend envía el header 'x-tenant-id'
# con el slug de la sede seleccionada.
#
# Sedes por defecto:
#   - yamborot        -> sena_db_yamborot
#   - centro-comercio -> sena_db_centro_comercio
# ============================================================
